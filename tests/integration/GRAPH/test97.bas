10 REM TEST97.BAS - SET/GET TILE COLOR ALL SYNTAXES
20 SCREEN 2
30 SET TILE ON
35 GOSUB 600
40 REM INLINE FC/BC FORM (BANK=DEFAULT 3=ALL)
41 SET TILE COLOR 65, 1, 15
42 PUT TILE 65, (10,5)
43 GOSUB 500
50 REM INLINE FC/BC FORM WITH BANK
51 SET TILE COLOR 66, 2, 8, 1
52 PUT TILE 66, (12,5)
53 GOSUB 500
60 REM PER-ROW FC ARRAY (NO BC, BANK=ALL)
70 SET TILE COLOR 67, (1,2,3,4,5,6,7,8)
71 PUT TILE 67, (14,5)
72 GOSUB 500
80 REM PER-ROW FC AND BC ARRAYS (BANK=ALL)
90 SET TILE COLOR 68, (1,2,3,4,5,6,7,8), (15,14,13,12,11,10,9,8)
91 PUT TILE 68, (16,5)
92 GOSUB 500
100 REM PER-ROW FC ARRAY WITH BANK
110 SET TILE COLOR 69, (8,7,6,5,4,3,2,1), 2
111 PUT TILE 69, (18,5)
112 GOSUB 500
120 REM BUFFER ARRAY FORM (4 INTEGER ARRAY, BANK=ALL)
130 DIM C%(3)
140 C%(0)=&H1F26 : C%(1)=&H3443 : C%(2)=&H5B6A : C%(3)=&H7C8D
150 SET TILE COLOR 70, C%()
151 PUT TILE 70, (20,5)
152 GOSUB 500
160 REM BUFFER ARRAY FORM WITH BANK
170 SET TILE COLOR 71, C%(), 1
171 PUT TILE 71, (22,5)
172 GOSUB 500
180 REM GET TILE COLOR (DEFAULT BANK 0)
190 DIM G%(3)
200 GET TILE COLOR 70, G%()
201 Y% = 18 : GOSUB 400
210 REM GET TILE COLOR WITH BANK
220 GET TILE COLOR 71, G%(), 1
221 Y% = 20 : GOSUB 400
230 GOSUB 500
240 SCREEN 0
241 END
300 PUT TILE 65, (10,Y%)
301 PUT TILE 66, (12,Y%)
302 PUT TILE 67, (14,Y%)
303 PUT TILE 68, (16,Y%)
304 PUT TILE 69, (18,Y%)
305 PUT TILE 70, (20,Y%)
306 PUT TILE 71, (22,Y%)
307 RETURN
400 LOCATE  0, Y% : PRINT HEX$(G%(0))
401 LOCATE  6, Y% : PRINT HEX$(G%(1))
402 LOCATE 12, Y% : PRINT HEX$(G%(2))
403 LOCATE 18, Y% : PRINT HEX$(G%(3))
404 RETURN
500 A$ = INPUT$(1)
502 RETURN
600 LOCATE 0,0 : PRINT "TEST97.BAS - SET/GET TILE COLOR"
601 LOCATE 0,1 : PRINT "PRESS KEY FOR EACH STEP"
602 RETURN
