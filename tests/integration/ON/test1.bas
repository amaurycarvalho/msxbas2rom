10 INPUT "Enter a number between 1 and 9"; N%
20 M$ = "WRONG NUMBER"
30 ON N% GOSUB 101, 102, 103, 104, 105, 106, 107, 108, 109
40 PRINT M$
50 GOTO 10

101 M$ = "ONE" : RETURN
102 M$ = "TWO" : RETURN
103 M$ = "THREE" : RETURN
104 M$ = "FOUR" : RETURN
105 M$ = "FIVE" : RETURN
106 M$ = "SIX" : RETURN
107 M$ = "SEVEN" : RETURN
108 M$ = "EIGHT" : RETURN
109 M$ = "NINE" : RETURN

